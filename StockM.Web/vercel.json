{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/**": { "memory": 256 }
  },
  "rewrites": [
    { "source": "/api/yahoo2/(.*)", "destination": "/api/yahoo2" },
    { "source": "/api/yahoo/(.*)",  "destination": "/api/yahoo" },
    { "source": "/api/fc/(.*)",     "destination": "/api/fc" },
    { "source": "/api/fc",          "destination": "/api/fc" },
    { "source": "/api/finnhub/(.*)", "destination": "/api/finnhub" },
    { "source": "/api/alphavantage/(.*)", "destination": "/api/alphavantage" }
  ]
}

<Window x:Class="StockM.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StockM.Desktop.ViewModels"
        xmlns:conv="clr-namespace:StockM.Desktop.Converters"
        Title="StockM — Algorithmic Stock Picker 2026"
        Width="1400" Height="900"
        MinWidth="1000" MinHeight="700"
        Background="{StaticResource PrimaryBgBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:ScoreToColorConverter x:Key="ScoreToColor"/>
        <conv:SignalToColorConverter x:Key="SignalToColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryBgBrush}" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📈" FontSize="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="StockM" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Algorithmic Stock Picker — 2026 Liquidity Model" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Search Bar -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBox Text="{Binding SymbolInput, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             Width="200" Margin="0,0,8,0"
                             FontSize="16" FontWeight="Bold"
                             VerticalContentAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AnalyzeCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Content="⚡ Analyze" Command="{Binding AnalyzeCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>

                <!-- API Key -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="API Key:" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}" Width="160"
                             FontSize="11" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Watchlist Quick Access -->
        <Border Grid.Row="1" Background="{StaticResource PrimaryBgBrush}" Padding="24,8">
            <ItemsControl ItemsSource="{Binding WatchlistSymbols}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding}" Margin="4,2" Padding="12,6" Cursor="Hand"
                                FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource CardBgBrush}" CornerRadius="6"
                                            Padding="{TemplateBinding Padding}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="18,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Chart + Signal -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Price Chart Area -->
                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Price Chart (Last 90 Days)"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                        <!-- Simple chart using ItemsControl with polyline -->
                        <Canvas Grid.Row="1" x:Name="ChartCanvas" ClipToBounds="True"
                                Background="Transparent" SizeChanged="ChartCanvas_SizeChanged"/>
                    </Grid>
                </Border>

                <!-- Current Signal Details -->
                <Border Grid.Row="1" Style="{StaticResource Card}"
                        Visibility="{Binding HasSignal, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Signal Badge -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="SIGNAL" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CurrentSignal.Signal}" FontSize="22" FontWeight="Bold"
                                       Foreground="{Binding CurrentSignal.Signal, Converter={StaticResource SignalToColor}}"/>
                        </StackPanel>

                        <!-- Score -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="MODEL SCORE" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CurrentSignal.ModelScore, StringFormat='{}{0:P1}'}" FontSize="22" FontWeight="Bold"
                                       Foreground="{Binding CurrentSignal.ModelScore, Converter={StaticResource ScoreToColor}}"/>
                        </StackPanel>

                        <!-- Entry -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="ENTRY" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CurrentSignal.EntryPrice, StringFormat='${0:F2}'}" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <!-- Stop Loss -->
                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                            <TextBlock Text="STOP LOSS" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CurrentSignal.StopLoss, StringFormat='${0:F2}'}" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource AccentRedBrush}"/>
                        </StackPanel>

                        <!-- Take Profit -->
                        <StackPanel Grid.Column="4" VerticalAlignment="Center">
                            <TextBlock Text="TAKE PROFIT" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CurrentSignal.TakeProfit, StringFormat='${0:F2}'}" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource AccentGreenBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right Sidebar: Indicators + Risk + History -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Indicators Panel -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding HasSignal, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="📊 Technical Indicators" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="MA 30" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentSignal.Indicators.MA30, StringFormat='${0:F2}'}"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="MA 120" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentSignal.Indicators.MA120, StringFormat='${0:F2}'}"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="RSI (14)" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentSignal.Indicators.RSI, StringFormat='{}{0:F1}'}"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Bollinger Upper" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentSignal.Indicators.BollingerUpper, StringFormat='${0:F2}'}"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Bollinger Lower" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentSignal.Indicators.BollingerLower, StringFormat='${0:F2}'}"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ATR (14)" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentSignal.Indicators.ATR, StringFormat='${0:F2}'}"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            </Grid>

                            <Border Margin="0,10,0,0" Padding="10,8" CornerRadius="8"
                                    Background="{StaticResource CardBgBrush}">
                                <StackPanel>
                                    <TextBlock Text="MA Crossover" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                    <TextBlock FontWeight="Bold" FontSize="14">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Bearish"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentSignal.Indicators.MACrossoverBullish}" Value="True">
                                                        <Setter Property="Text" Value="Bullish ✓"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Risk Panel -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding HasSignal, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="🛡️ Risk Management" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Shares" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentRisk.ShareCount}"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Max Loss" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentRisk.MaxLoss, StringFormat='-${0:F2}'}"
                                           Foreground="{StaticResource AccentRedBrush}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Max Gain" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentRisk.MaxGain, StringFormat='+${0:F2}'}"
                                           Foreground="{StaticResource AccentGreenBrush}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Risk/Reward" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentRisk.RiskRewardRatio, StringFormat='1:{0:F1}'}"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold"/>
                            </Grid>

                            <Border Margin="0,8,0,0" Padding="8,6" CornerRadius="6"
                                    Background="{StaticResource CardBgBrush}">
                                <TextBlock Text="{Binding CurrentSignal.Reasoning}" TextWrapping="Wrap"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Signal History -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="📋 Signal History" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                            <ItemsControl ItemsSource="{Binding Signals}" MaxHeight="300">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" Margin="0,2" CornerRadius="6"
                                                Background="{StaticResource CardBgBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Symbol}" FontWeight="Bold" FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Signal}" FontSize="12"
                                                           Foreground="{Binding Signal, Converter={StaticResource SignalToColor}}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding ModelScore, StringFormat='{}{0:P0}'}"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{Binding ModelScore, Converter={StaticResource ScoreToColor}}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{StaticResource SecondaryBgBrush}" Padding="24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentBlueBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="H-BLSTM + XGBoost Model | Walk-Forward Validated"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Border Grid.RowSpan="4" Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Analyzing..." FontSize="18" Foreground="White" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
